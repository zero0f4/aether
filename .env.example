# AETHER — Wireless Network Intelligence Console
# Voorkeur: configureer via /setup in de browser. Alle waarden hieronder zijn
# documentatie — laat ze leeg als je de setup-wizard gebruikt.

# ─── UniFi controller (vereist) ────────────────────────────────
# Host = IP of hostname van je UDM/UDR/Cloud Key.
# User/pass = lokale read-only admin (Settings → Admins & Users).
UDM_HOST=
UDM_USER=
UDM_PASS=
UDM_SITE=default

# ─── Server ────────────────────────────────────────────────────
PORT=3033
POLL_MS=1500
RETENTION_DAYS=7

# ─── WiGLE.net wardrive lookup (optioneel) ─────────────────────
# Maak een gratis account op https://wigle.net/account → "Show My Token".
# De "Encoded for use" base64-string decodeer je tot "userId:apiToken".
WIGLE_USER=
WIGLE_KEY=

# ─── Toegangscontrole (optioneel) ──────────────────────────────
# Laat leeg voor open localhost-toegang. Anders een random 32-byte hex.
# Bearer-token via Authorization: Bearer <token> of ?token=<token>.
AUTH_TOKEN=
READONLY_TOKEN=

# ─── Zigbee / Home Assistant ZHA (optioneel) ──────────────────
# Schakelt de ZIGBEE-tab in: live mesh-graph, LQI-edges, end-devices die
# clusteren rond hun parent-router, en een Zigbee-band over SPECTRUM 2.4 GHz
# zodat je WiFi/Zigbee-overlap in één oogopslag ziet.
#
# Vereisten:
#   1. Home Assistant met de ZHA-integratie actief (geen Zigbee2MQTT-support)
#   2. HA bereikbaar vanaf AETHER op http(s)://host:port
#   3. Een long-lived access token (HA → profiel → "Long-Lived Access Tokens")
#
# HA_URL: bv. http://homeassistant.local:8123
# HA_TOKEN: long-lived access token. AETHER vraagt alleen-lezen ZHA-data op.
HA_URL=
HA_TOKEN=
ZIGBEE_REFRESH_MS=15000
