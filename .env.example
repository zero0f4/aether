# Vul in via setup-wizard op /setup, of handmatig hier.
# Geen IP-default — moet je eigen UniFi-controller-IP zijn.
UDM_HOST=
UDM_USER=
UDM_PASS=
UDM_SITE=default
PORT=3033
POLL_MS=1500

# Optioneel — WiGLE.net wardrive-database (https://wigle.net/account)
# Met deze credentials kun je in de RECON-tab elke neighbor-BSSID
# opzoeken in de wereldwijde crowdsourced database.
WIGLE_USER=
WIGLE_KEY=
